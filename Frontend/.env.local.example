# Browser-facing FastAPI URL. Local dev: http://localhost:8001
# Docker internal option when browser/network can resolve service DNS: http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8001

# Server-side FastAPI URL used by Next.js server components such as the public portal.
API_INTERNAL_URL=http://localhost:8001

# Public app origin used for generated portal links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Must match Backend SECRET_KEY so BetterAuth JWTs validate in FastAPI.
BETTER_AUTH_SECRET=

# BetterAuth server origin.
BETTER_AUTH_URL=http://localhost:3000

# BetterAuth browser-facing origin.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# PostgreSQL URL used by BetterAuth. Use a normal postgresql:// URL, not postgresql+asyncpg://.
DATABASE_URL=
